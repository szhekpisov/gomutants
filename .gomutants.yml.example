# gomutants configuration
# Copy this file to .gomutants.yml in your project root.
# All fields are optional — defaults are shown below.
# Priority: built-in defaults < this file < CLI flags.

# Number of parallel workers (default: number of CPUs).
workers: 10

# Value passed to inner `go test -cpu` per mutant. 0 (the default)
# omits the flag so go test inherits GOMAXPROCS. Pair --workers=1
# with a higher --test-cpu when you want one fat go-test child rather
# than many narrow ones.
test-cpu: 0

# Per-mutant timeout = baseline test duration * this coefficient (default: 10).
timeout-coefficient: 10

# Coverage package pattern passed to go test -coverpkg.
# Useful when your tests are in a separate package from the code under test.
# coverpkg: "./pkg/..."

# JSON report output path (default: mutation-report.json).
output: mutation-report.json

# Suppress header, phase banners, per-mutant progress, and the trailing
# "Report:" line. Only the final summary block lands on stdout; stderr
# warnings are unaffected. Mutually exclusive with --verbose.
# quiet: false

# Scope mutation testing to lines changed since the given git ref
# (e.g. "origin/main", "HEAD~1"). Empty disables; --changed-since on
# the CLI overrides. Requires a git repository.
# changed-since: ""

# Incremental-analysis cache path. The default (".gomutants-cache.json")
# enables caching at that path; set to "off" to disable. Per-mutant
# outcomes are keyed by content hashes of the production file and the
# test files that cover the mutant (resolved from the per-test coverage
# map; falls back to all _test.go in the mutant's package directory).
# On the next run, mutants whose source and covering tests are byte-
# identical to the cached run are skipped.
# cache: .gomutants-cache.json

# How often to flush completed mutant outcomes to the cache file while a
# run is still in progress (default: 10s). A run killed mid-way — OOM, CI
# timeout, SIGKILL, double Ctrl-C — loses at most this much progress; the
# next invocation resumes from the last checkpoint instead of starting
# over. Set to 0s to disable periodic checkpointing (the cache is then
# written only once, at the end of the run). Ignored when cache is "off".
# checkpoint-interval: 10s

# Mutator types to disable (run all except these).
# disable:
#   - BRANCH_IF
#   - BRANCH_ELSE

# Mutator types to run exclusively (disables all others).
# only:
#   - ARITHMETIC_BASE
#   - CONDITIONALS_NEGATION

# Available mutator types (16 total):
#   Token-level:
#     ARITHMETIC_BASE             — swap +/-, */%, etc.
#     CONDITIONALS_BOUNDARY       — swap </<=, >/>=
#     CONDITIONALS_NEGATION       — swap ==/!=, </>=, >/<=
#     INCREMENT_DECREMENT         — swap ++/--
#     INVERT_NEGATIVES            — swap -/+ (unary and binary)
#     INVERT_ASSIGNMENTS          — swap arithmetic compound assignments (+=/-=, etc.)
#     INVERT_BITWISE              — swap bitwise binary ops (&/|, ^, <<, >>)
#     INVERT_BITWISE_ASSIGNMENTS  — swap bitwise compound assignments (&=/|=, etc.)
#     INVERT_LOGICAL              — swap &&/||
#     INVERT_LOOP_CTRL            — swap break/continue
#     REMOVE_SELF_ASSIGNMENTS     — drop op from compound assignment (`x += y` → `x = y`)
#   Block-level:
#     BRANCH_IF                   — empty if/else-if body
#     BRANCH_ELSE                 — empty else body
#     BRANCH_CASE                 — empty case clause body
#     EXPRESSION_REMOVE           — replace &&/|| operand with true/false
#     STATEMENT_REMOVE            — remove assignment/expression/increment side-effects
